{
  "name": "loom-ai-v1-ui",
  "private": true,
  "version": "0.1.0-beta.3",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "electron:dev": "node electron/dev.mjs",
    "electron:build": "npm run build",
    "electron:preview": "electron electron/main.mjs",
    "electron:package:dev": "cargo build --manifest-path services/loom-service/Cargo.toml --release && npm run build && node electron/package-dev.mjs",
    "electron:package:mac:arm64": "cargo build --manifest-path services/loom-service/Cargo.toml --release --target aarch64-apple-darwin && npm run build && node electron/package-mac-arm64.mjs",
    "electron:dist:mac:arm64": "npm run electron:package:mac:arm64 && node electron/dist-mac-arm64.mjs",
    "test:e2e": "playwright test",
    "service:dev": "cargo run --manifest-path services/loom-service/Cargo.toml",
    "service:check": "cargo check --manifest-path services/loom-service/Cargo.toml",
    "service:test": "cargo test --manifest-path services/loom-service/Cargo.toml",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "build": {
    "mac": {
      "icon": "build-assets/loom_logo.icns"
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "@xyflow/react": "^12.10.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "electron": "^41.6.1",
    "vitest": "^4.1.7"
  }
}
